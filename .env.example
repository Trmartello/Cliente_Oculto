# Banco de dados MySQL (Railway: usar reference variable do addon MySQL)
DATABASE_URL="mysql://oculto:oculto_dev@127.0.0.1:3306/cliente_oculto"

# Segredo para assinatura dos JWTs de sessão — OBRIGATÓRIO em runtime
# (gerar com: openssl rand -hex 32). Sem ele a aplicação lança erro.
AUTH_SECRET="troque-este-segredo-em-producao"

# URL pública da aplicação. OPCIONAL em produção: se ausente, o link do
# avaliador é montado a partir do proxy (x-forwarded-*). Só defina se NÃO
# for localhost. Nunca aponte para localhost em produção.
APP_URL="http://localhost:3000"

# Armazenamento de fotos: "local" (dev) ou "s3" (produção — R2/B2/MinIO).
# O filesystem do Railway é efêmero: use s3 em produção.
STORAGE_DRIVER="local"

# Somente quando STORAGE_DRIVER=s3 (Cloudflare R2, Backblaze B2, MinIO)
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# E-mail (OPCIONAL). Sem SMTP o sistema funciona — os envios viram log.
# Necessário para: alerta de NC aberta, resumo de vencidos e o link de
# "esqueci minha senha". SMTP_FROM é o remetente exibido.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Cliente Oculto <no-reply@suarede.com.br>"

# Segredo do cron de notificações (OPCIONAL). Defina para habilitar o
# resumo diário de pendências vencidas em GET /api/tarefas/notificar
# (Authorization: Bearer $CRON_SECRET). Sem ele a rota responde 503.
CRON_SECRET=""
