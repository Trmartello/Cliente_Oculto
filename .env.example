# Banco de dados MySQL (Railway: usar reference variable do addon MySQL)
DATABASE_URL="mysql://oculto:oculto_dev@127.0.0.1:3306/cliente_oculto"

# Segredo para assinatura dos JWTs de sessão (gerar com: openssl rand -hex 32)
AUTH_SECRET="troque-este-segredo-em-producao"

# URL pública da aplicação (usada para montar o link do avaliador)
APP_URL="http://localhost:3000"

# Armazenamento de fotos: "local" (dev) ou "s3" (produção — R2/B2/MinIO)
STORAGE_DRIVER="local"

# Somente quando STORAGE_DRIVER=s3
S3_ENDPOINT=""
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
